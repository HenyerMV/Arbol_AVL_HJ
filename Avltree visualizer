<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AVL Tree Visualizer</title>
<style>
/* ─── FUENTES ─────────────────────────────────────────── */
@import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Rajdhani:wght@400;600;700&display=swap');

/* ─── VARIABLES DE TEMA ───────────────────────────────── */
:root {
  --transition: 0.3s ease;
}

[data-theme="dark"] {
  --bg-primary:    #0a0a0f;
  --bg-secondary:  #111118;
  --bg-surface:    #16161f;
  --bg-card:       #1a1a26;
  --accent:        #7c3aed;
  --accent-bright: #a855f7;
  --accent-glow:   rgba(124,58,237,0.35);
  --accent-dim:    #4c1d95;
  --node-fill:     #6d28d9;
  --node-stroke:   #a855f7;
  --node-text:     #f5f3ff;
  --edge-color:    #7c3aed;
  --edge-dim:      #3b1f6e;
  --text-primary:  #e9e5ff;
  --text-secondary:#a89bc2;
  --text-muted:    #5c5475;
  --border:        #2d2445;
  --border-bright: #5b21b6;
  --btn-bg:        #1e1b2e;
  --btn-hover:     #2d2850;
  --btn-active:    #4c1d95;
  --input-bg:      #12111a;
  --canvas-bg:     #0d0d14;
  --highlight:     #f0abfc;
  --success:       #34d399;
  --warning:       #fbbf24;
  --danger:        #f87171;
  --shadow:        0 4px 24px rgba(124,58,237,0.2);
  --node-visiting: #a855f7;
  --node-inserted: #34d399;
  --node-rotate:   #fbbf24;
}

[data-theme="light"] {
  --bg-primary:    #f8f9ff;
  --bg-secondary:  #f0f0fb;
  --bg-surface:    #e8e8f8;
  --bg-card:       #ffffff;
  --accent:        #1d4ed8;
  --accent-bright: #2563eb;
  --accent-glow:   rgba(29,78,216,0.2);
  --accent-dim:    #bfdbfe;
  --node-fill:     #2563eb;
  --node-stroke:   #1d4ed8;
  --node-text:     #ffffff;
  --edge-color:    #3b82f6;
  --edge-dim:      #bfdbfe;
  --text-primary:  #0f172a;
  --text-secondary:#334155;
  --text-muted:    #94a3b8;
  --border:        #cbd5e1;
  --border-bright: #3b82f6;
  --btn-bg:        #f1f5f9;
  --btn-hover:     #dbeafe;
  --btn-active:    #bfdbfe;
  --input-bg:      #ffffff;
  --canvas-bg:     #f0f4ff;
  --highlight:     #7c3aed;
  --success:       #059669;
  --warning:       #d97706;
  --danger:        #dc2626;
  --shadow:        0 4px 24px rgba(29,78,216,0.15);
  --node-visiting: #1d4ed8;
  --node-inserted: #059669;
  --node-rotate:   #d97706;
}

/* ─── RESET & BASE ────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Rajdhani', sans-serif;
  background: var(--bg-primary);
  color: var(--text-primary);
  min-height: 100vh;
  transition: background var(--transition), color var(--transition);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ─── HEADER ──────────────────────────────────────────── */
header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  height: 56px;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border);
  position: relative;
  z-index: 10;
  flex-shrink: 0;
}

.header-title {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo-icon {
  width: 32px; height: 32px;
  border: 2px solid var(--accent-bright);
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  font-weight: 700;
  color: var(--accent-bright);
  box-shadow: 0 0 10px var(--accent-glow);
  transition: box-shadow var(--transition);
}

h1 {
  font-size: 20px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-primary);
}

h1 span {
  color: var(--accent-bright);
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

/* ─── THEME TOGGLE ────────────────────────────────────── */
.theme-toggle {
  position: relative;
  width: 52px; height: 26px;
  background: var(--btn-bg);
  border: 1px solid var(--border);
  border-radius: 13px;
  cursor: pointer;
  transition: background var(--transition);
}
.theme-toggle::after {
  content: '';
  position: absolute;
  top: 3px; left: 3px;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: var(--accent-bright);
  transition: transform 0.3s cubic-bezier(.4,0,.2,1), background var(--transition);
  box-shadow: 0 0 6px var(--accent-glow);
}
[data-theme="light"] .theme-toggle::after {
  transform: translateX(26px);
  background: var(--accent);
}
.theme-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1px;
  color: var(--text-muted);
  text-transform: uppercase;
}

/* ─── LAYOUT PRINCIPAL ────────────────────────────────── */
.main-layout {
  display: flex;
  flex: 1;
  overflow: hidden;
  height: calc(100vh - 56px);
}

/* ─── PANEL IZQUIERDO ─────────────────────────────────── */
.left-panel {
  width: 260px;
  flex-shrink: 0;
  background: var(--bg-secondary);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  padding: 16px;
  gap: 16px;
}

.panel-section {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px;
}

.section-title {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 6px;
}
.section-title::before {
  content: '';
  display: inline-block;
  width: 3px; height: 12px;
  background: var(--accent-bright);
  border-radius: 2px;
}

/* ─── INPUT + BOTONES ─────────────────────────────────── */
.input-row {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.num-input {
  flex: 1;
  background: var(--input-bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-primary);
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  padding: 8px 10px;
  outline: none;
  transition: border-color var(--transition), box-shadow var(--transition);
}
.num-input:focus {
  border-color: var(--accent-bright);
  box-shadow: 0 0 0 2px var(--accent-glow);
}
.num-input::placeholder { color: var(--text-muted); }

.btn {
  padding: 8px 14px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: var(--btn-bg);
  color: var(--text-primary);
  font-family: 'Rajdhani', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.5px;
  cursor: pointer;
  transition: background var(--transition), border-color var(--transition), 
              box-shadow var(--transition), transform 0.1s;
  white-space: nowrap;
}
.btn:hover {
  background: var(--btn-hover);
  border-color: var(--accent-bright);
}
.btn:active { transform: scale(0.97); }

.btn-primary {
  background: var(--accent);
  border-color: var(--accent-bright);
  color: #fff;
  box-shadow: 0 0 12px var(--accent-glow);
}
.btn-primary:hover {
  background: var(--accent-bright);
  box-shadow: 0 0 18px var(--accent-glow);
}

.btn-danger {
  border-color: var(--danger);
  color: var(--danger);
}
.btn-danger:hover {
  background: rgba(248,113,113,0.1);
}

.btn-full { width: 100%; justify-content: center; display: flex; }

.btn-row {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

/* ─── CONTROLES DE VELOCIDAD ──────────────────────────── */
.speed-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 4px;
}
.speed-label {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 600;
  letter-spacing: 1px;
  min-width: 36px;
}
input[type="range"] {
  flex: 1;
  -webkit-appearance: none;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  outline: none;
  cursor: pointer;
}
input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 14px; height: 14px;
  border-radius: 50%;
  background: var(--accent-bright);
  box-shadow: 0 0 6px var(--accent-glow);
  cursor: pointer;
  transition: transform 0.15s;
}
input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.2); }

/* ─── CONTROLES DE REPRODUCCIÓN ──────────────────────── */
.playback-controls {
  display: flex;
  gap: 8px;
  align-items: center;
  justify-content: center;
}

.ctrl-btn {
  width: 36px; height: 36px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--btn-bg);
  color: var(--text-primary);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background var(--transition), border-color var(--transition),
              box-shadow var(--transition), transform 0.1s;
  font-size: 13px;
}
.ctrl-btn:hover {
  background: var(--btn-hover);
  border-color: var(--accent-bright);
  box-shadow: 0 0 10px var(--accent-glow);
}
.ctrl-btn:active { transform: scale(0.93); }
.ctrl-btn.play-btn {
  width: 42px; height: 42px;
  background: var(--accent);
  border-color: var(--accent-bright);
  box-shadow: 0 0 14px var(--accent-glow);
}
.ctrl-btn.play-btn:hover { background: var(--accent-bright); }
.ctrl-btn:disabled { opacity: 0.35; cursor: not-allowed; pointer-events: none; }

/* ─── LOG DE PASOS ────────────────────────────────────── */
.step-log {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  line-height: 1.7;
  color: var(--text-secondary);
  max-height: 180px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.step-log::-webkit-scrollbar { width: 4px; }
.step-log::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.log-entry {
  padding: 2px 4px;
  border-radius: 3px;
  animation: fadeIn 0.3s ease;
}
.log-entry.active {
  background: var(--btn-hover);
  color: var(--accent-bright);
}
.log-entry.rotate { color: var(--node-rotate); }
.log-entry.insert { color: var(--node-inserted); }
.log-entry.search { color: var(--node-visiting); }
.log-entry.balance { color: var(--highlight); }

@keyframes fadeIn { from { opacity: 0; transform: translateX(-4px); } to { opacity: 1; } }

/* ─── CANVAS ÁREA ─────────────────────────────────────── */
.canvas-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  background: var(--bg-primary);
  position: relative;
  overflow: hidden;
}

#avl-canvas {
  flex: 1;
  display: block;
  background: var(--canvas-bg);
  cursor: crosshair;
  transition: background var(--transition);
}

/* ─── STATUS BAR ──────────────────────────────────────── */
.status-bar {
  height: 32px;
  background: var(--bg-secondary);
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 20px;
  flex-shrink: 0;
}

.status-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.5px;
  color: var(--text-muted);
}
.status-item .val {
  font-family: 'Space Mono', monospace;
  color: var(--text-secondary);
}
.status-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--success);
  box-shadow: 0 0 4px var(--success);
}
.status-dot.busy { background: var(--warning); box-shadow: 0 0 4px var(--warning); }

/* ─── INDICADOR DE BALANCE ────────────────────────────── */
.balance-badge {
  display: inline-flex;
  align-items: center;
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 10px;
  font-family: 'Space Mono', monospace;
  font-weight: 700;
  border: 1px solid;
}
.balance-badge.ok     { background: rgba(52,211,153,0.1); color: var(--success); border-color: var(--success); }
.balance-badge.warn   { background: rgba(251,191,36,0.1);  color: var(--warning); border-color: var(--warning); }
.balance-badge.error  { background: rgba(248,113,113,0.1); color: var(--danger);  border-color: var(--danger); }

/* ─── INFO PANEL (derecha) ────────────────────────────── */
.right-panel {
  width: 200px;
  flex-shrink: 0;
  background: var(--bg-secondary);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  padding: 16px;
  gap: 14px;
  overflow-y: auto;
}

.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  text-align: center;
}
.stat-value {
  font-family: 'Space Mono', monospace;
  font-size: 22px;
  font-weight: 700;
  color: var(--accent-bright);
  line-height: 1;
  margin-bottom: 4px;
}
.stat-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text-muted);
}

/* ─── LEYENDA ─────────────────────────────────────────── */
.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  color: var(--text-secondary);
  padding: 3px 0;
}
.legend-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ─── TOOLTIP ─────────────────────────────────────────── */
#tooltip {
  position: fixed;
  background: var(--bg-card);
  border: 1px solid var(--border-bright);
  border-radius: 6px;
  padding: 6px 10px;
  font-size: 12px;
  font-family: 'Space Mono', monospace;
  color: var(--text-primary);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.15s;
  z-index: 100;
  box-shadow: var(--shadow);
  white-space: nowrap;
}
#tooltip.visible { opacity: 1; }

/* ─── ANIMACIÓN DE CARGA ──────────────────────────────── */
@keyframes pulse-accent {
  0%, 100% { box-shadow: 0 0 10px var(--accent-glow); }
  50%       { box-shadow: 0 0 22px var(--accent-glow), 0 0 40px var(--accent-glow); }
}
.logo-icon { animation: pulse-accent 3s ease-in-out infinite; }

/* ─── SCROLLBAR GLOBAL ────────────────────────────────── */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--border-bright); }

/* ─── RESPONSIVO MÍNIMO ───────────────────────────────── */
@media (max-width: 900px) {
  .right-panel { display: none; }
}
@media (max-width: 640px) {
  .left-panel { width: 200px; }
}
</style>
</head>
<body>

<!-- ═══════════════ HEADER ═══════════════ -->
<header>
  <div class="header-title">
    <div class="logo-icon">AVL</div>
    <h1><span>AVL</span> TREE</h1>
  </div>
  <div class="header-right">
    <span class="theme-label" id="theme-label">DARK</span>
    <div class="theme-toggle" id="theme-toggle" title="Cambiar tema"></div>
  </div>
</header>

<!-- ═══════════════ LAYOUT ═══════════════ -->
<div class="main-layout">

  <!-- ── PANEL IZQUIERDO ── -->
  <aside class="left-panel">

    <!-- INSERTAR -->
    <div class="panel-section">
      <div class="section-title">Insertar</div>
      <div class="input-row">
        <input class="num-input" type="number" id="insert-val" placeholder="ej: 42" min="-999" max="999">
        <button class="btn btn-primary" id="btn-insert">+ INS</button>
      </div>
      <div class="btn-row">
        <button class="btn" id="btn-insert-random" style="flex:1">Aleatorio</button>
        <button class="btn" id="btn-insert-seq" style="flex:1">Secuencia</button>
      </div>
    </div>

    <!-- BUSCAR / ELIMINAR -->
    <div class="panel-section">
      <div class="section-title">Buscar / Eliminar</div>
      <div class="input-row">
        <input class="num-input" type="number" id="search-val" placeholder="valor" min="-999" max="999">
      </div>
      <div class="btn-row">
        <button class="btn" id="btn-search" style="flex:1">🔍 Buscar</button>
        <button class="btn btn-danger" id="btn-delete" style="flex:1">✕ Eliminar</button>
      </div>
    </div>

    <!-- REPRODUCCIÓN -->
    <div class="panel-section">
      <div class="section-title">Reproducción</div>
      <div class="playback-controls" style="margin-bottom:12px">
        <button class="ctrl-btn" id="btn-undo"  title="Deshacer paso">↩</button>
        <button class="ctrl-btn" id="btn-step-back" title="Paso anterior">⏮</button>
        <button class="ctrl-btn play-btn" id="btn-play" title="Play / Pause">▶</button>
        <button class="ctrl-btn" id="btn-step-fwd"  title="Paso siguiente">⏭</button>
        <button class="ctrl-btn" id="btn-stop" title="Reiniciar animación">⏹</button>
      </div>
      <div class="speed-row">
        <span class="speed-label">VEL</span>
        <input type="range" id="speed-slider" min="1" max="10" value="5">
        <span class="speed-label" id="speed-val">5</span>
      </div>
    </div>

    <!-- ÁRBOL -->
    <div class="panel-section">
      <div class="section-title">Árbol</div>
      <div class="btn-row" style="flex-direction:column;gap:6px">
        <button class="btn btn-full" id="btn-clear">🗑 Limpiar árbol</button>
        <button class="btn btn-full" id="btn-balance-check">⚖ Verificar balance</button>
        <button class="btn btn-full" id="btn-recenter">⊙ Centrar vista</button>
      </div>
    </div>

    <!-- LOG -->
    <div class="panel-section" style="flex:1;min-height:100px">
      <div class="section-title">Log de pasos</div>
      <div class="step-log" id="step-log">
        <div class="log-entry">Sistema listo. Inserta un valor para comenzar.</div>
      </div>
    </div>

  </aside>

  <!-- ── CANVAS CENTRAL ── -->
  <main class="canvas-area">
    <canvas id="avl-canvas"></canvas>
    <div class="status-bar">
      <div class="status-item"><div class="status-dot" id="status-dot"></div><span id="status-text">Listo</span></div>
      <div class="status-item">NODOS: <span class="val" id="stat-nodes">0</span></div>
      <div class="status-item">ALTURA: <span class="val" id="stat-height">—</span></div>
      <div class="status-item">PASO: <span class="val" id="stat-step">0/0</span></div>
      <div class="status-item" id="balance-status"></div>
    </div>
  </main>

  <!-- ── PANEL DERECHO ── -->
  <aside class="right-panel">
    <div class="section-title">Estadísticas</div>
    <div class="stat-card"><div class="stat-value" id="rp-nodes">0</div><div class="stat-label">Nodos</div></div>
    <div class="stat-card"><div class="stat-value" id="rp-height">0</div><div class="stat-label">Altura</div></div>
    <div class="stat-card"><div class="stat-value" id="rp-rotations">0</div><div class="stat-label">Rotaciones</div></div>
    <div class="stat-card"><div class="stat-value" id="rp-ops">0</div><div class="stat-label">Operaciones</div></div>

    <div class="section-title" style="margin-top:8px">Leyenda</div>
    <div style="display:flex;flex-direction:column;gap:2px">
      <div class="legend-item">
        <div class="legend-dot" style="background:var(--node-fill)"></div>Normal
      </div>
      <div class="legend-item">
        <div class="legend-dot" style="background:var(--node-visiting)"></div>Visitando
      </div>
      <div class="legend-item">
        <div class="legend-dot" style="background:var(--node-inserted)"></div>Insertado
      </div>
      <div class="legend-item">
        <div class="legend-dot" style="background:var(--node-rotate)"></div>Rotando
      </div>
      <div class="legend-item">
        <div class="legend-dot" style="background:var(--danger)"></div>Desbalanceado
      </div>
    </div>

    <div class="section-title" style="margin-top:8px">Recorridos</div>
    <div style="display:flex;flex-direction:column;gap:6px">
      <button class="btn btn-full" id="btn-inorder">InOrden</button>
      <button class="btn btn-full" id="btn-preorder">PreOrden</button>
      <button class="btn btn-full" id="btn-postorder">PostOrden</button>
    </div>
  </aside>

</div>

<!-- TOOLTIP -->
<div id="tooltip"></div>

<!-- ═══════════════ JAVASCRIPT ═══════════════ -->
<script>
'use strict';

/* ─────────────────────────────────────────────────
   MÓDULO: THEME MANAGER
───────────────────────────────────────────────── */
const ThemeManager = (() => {
  const toggle = document.getElementById('theme-toggle');
  const label  = document.getElementById('theme-label');
  const html   = document.documentElement;

  function set(theme) {
    html.setAttribute('data-theme', theme);
    label.textContent = theme === 'dark' ? 'DARK' : 'LIGHT';
    localStorage.setItem('avl-theme', theme);
    if (window.AVLCanvas) window.AVLCanvas.redraw();
  }

  function init() {
    const saved = localStorage.getItem('avl-theme') || 'dark';
    set(saved);
    toggle.addEventListener('click', () => {
      set(html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
    });
  }

  function getVar(name) {
    return getComputedStyle(html).getPropertyValue(name).trim();
  }

  return { init, getVar };
})();

